{
  "name": "@regarde/ui",
  "description": "Regarde UI Components — This is a private library for the Regarde project. You shouldn't use it directly in your own projects.",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/components/atoms/*.d.ts",
      "import": "./dist/components/atoms/*.mjs",
      "require": "./dist/components/atoms/*.js"
    },
    "./ui/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.mjs",
      "require": "./dist/components/ui/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.mjs",
      "require": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "rm -rf dist && tsup",
    "lint": "oxlint .",
    "format": "oxfmt \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-table": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "little-timestamp": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "0.4.6",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
